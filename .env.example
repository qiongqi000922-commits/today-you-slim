# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
HTTP_PORT=0
BASE_PATH=
DATA_DIR=./data
ALLOWED_HOSTS=localhost,127.0.0.1
TRUSTED_PROXY_IPS=127.0.0.1,::1

# HTTPS, optional when running Node directly with TLS.
SSL_KEY_PATH=
SSL_CERT_PATH=

# QQ OAuth
QQ_APP_ID=
QQ_APP_KEY=
QQ_CALLBACK_URL=http://localhost:3000/api/auth/qq/callback
QQ_AUTH_SCOPE=get_user_info
QQ_ONLY_LOGIN=1

# Admin
ADMIN_PATH=/admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_IDLE_TIMEOUT_SECONDS=1800

# AI summary and nutrition completion
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Qwen vision and mood generation
ALIYUN_QWEN_API_KEY=
ALIYUN_QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_QWEN_MODEL=qwen3.5-plus
ALIYUN_QWEN_FALLBACK_MODELS=qwen3-vl-plus
FOOD_RECOGNITION_PRIORITY=qwen_vl

# Text safety moderation
TENCENT_TMS_SECRET_ID=
TENCENT_TMS_SECRET_KEY=
TENCENT_TMS_BIZ_TYPE=
TENCENT_TMS_REGION=ap-guangzhou
TEXT_SAFETY_FAIL_CLOSED=1

# Optional legacy food recognition providers, disabled unless keys are provided.
TIANAPI_FOOD_KEY=
BAIDU_DISH_API_KEY=
BAIDU_DISH_SECRET_KEY=
LOGMEAL_API_TOKEN=
LOGMEAL_COMPANY_TOKEN=

# Limits
MAX_PHOTO_BYTES=10485760
MAX_DAILY_BODY_RECORDS_PER_USER=20
MAX_DAILY_FOOD_RECORDS_PER_USER=20
RATE_LIMIT_ENABLED=1
RATE_LIMIT_GLOBAL_PER_MINUTE=260
RATE_LIMIT_API_PER_MINUTE=140
RATE_LIMIT_UPLOAD_PER_10_MINUTES=28
RATE_LIMIT_USER_UPLOAD_PER_10_MINUTES=18
RATE_LIMIT_USER_TEXT_PER_MINUTE=20
RATE_LIMIT_USER_AI_PER_HOUR=12
